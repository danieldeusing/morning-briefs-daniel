{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__Claude_Preview__preview_eval|mcp__Claude_Preview__preview_screenshot|mcp__Claude_Preview__preview_navigate|mcp__Claude_in_Chrome__navigate",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/stale_lib_port_guard.py\"",
            "statusMessage": "port-guard: checking for stale-lib verification"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/brief_gate.py\"",
            "statusMessage": "brief-gate: validating brief"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/tools/manifest_autobuild_hook.sh\"",
            "statusMessage": "manifest-autobuild: rebuilding dashboard"
          }
        ]
      }
    ]
  }
}
